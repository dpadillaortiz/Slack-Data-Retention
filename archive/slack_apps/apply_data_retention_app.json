{
    "display_information": {
        "name": "Apply Data Retention",
        "description": "This is used to apply the data retention policy of a channel",
        "background_color": "#ff0000"
    },
    "features": {
        "bot_user": {
            "display_name": "Apply Data Retention",
            "always_online": false
        }
    },
    "oauth_config": {
        "scopes": {
            "user": [
                "admin.conversations:write"
            ],
            "bot": [
                "channels:read"
            ]
        }
    },
    "settings": {
	"org_deploy_enabled": true,
        "socket_mode_enabled": false,
        "token_rotation_enabled": false
    }
}